{
  "name": "0x0-gen",
  "private": true,
  "packageManager": "pnpm@9.15.4",
  "scripts": {
    "dev": "turbo run dev --parallel --filter=@0x0-gen/gateway --filter=@0x0-gen/hub",
    "build": "turbo run build",
    "test": "turbo run test",
    "lint": "turbo run lint",
    "desktop": "concurrently \"pnpm --filter @0x0-gen/gateway dev\" \"pnpm --filter @0x0-gen/hub dev -- --host 0.0.0.0 --port 5173\" \"pnpm --filter @0x0-gen/desktop tauri:dev\"",
    "validate:workspace-build": "pnpm build"
  },
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "^8.21.0",
    "@typescript-eslint/parser": "^8.21.0",
    "concurrently": "^9.1.2",
    "eslint": "^9.18.0",
    "eslint-config-prettier": "^9.1.0",
    "prettier": "^3.4.2",
    "turbo": "^2.3.3",
    "typescript": "^5.7.3"
  }
}
